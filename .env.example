# API 服务地址 (后端接口服务地址)
# 默认值: http://127.0.0.1:8000
API_URL="http://127.0.0.1:8000"

# DODO 支付配置 (商品价格/套餐 ID)
# 用于前端渲染购买不同数量“墨水”的套餐
NEXT_PUBLIC_DODO_PRICE_INK_4=""
NEXT_PUBLIC_DODO_PRICE_INK_12=""
NEXT_PUBLIC_DODO_PRICE_INK_30=""

# Cloudflare Turnstile 验证码配置 (人机验证)
# 在 AuthForm 和 ChatUI 中使用
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# PostHog 用户行为数据分析配置
# 用于应用内埋点统计
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
